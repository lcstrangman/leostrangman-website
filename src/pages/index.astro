---
import Button from '@components/Button/Button.astro';
import Icon from '@components/Icon/Icon.astro';
import Image from '@components/Image/Image.astro';
import Wysiwyg from '@components/Wysiwyg/Wysiwyg.astro';
import Accordion from '@components/Accordion/Accordion.astro';

import Layout from '../layouts/Layout.astro';
---
<Layout title="Leo Strangman.">

    <!-- Hero Section Container -->
    <div class="hero page-background" id="parallax-hero">
         <!-- Fullscreen background image as canvas -->
        <canvas class = "parallax-canvas" id = "parallax-canvas"></canvas>
         <!-- Text/svg logo in hero section -->
        <div class="hero-content">
             <!-- Name title text -->
            <h1 class = "title-font u-text-amber-200 u-mix-blend-exclusion" id = "parallax-name">Leo Strangman.</h1>
            <h1 class = "title-font parallax-name-copy" id = "parallax-name-copy">Leo Strangman.</h1>
             <!-- Secondary heading text/svg -->
            <div class = "icon-text-wrapper u-text-amber-200 u-mix-blend-exclusion">
                <div id = "parallax-logo"><Icon name="icon-amber-supply" class = "icon"/></div>
                <h2 id = "parallax-title">Developer</h2>
            </div>
        </div>
    </div>

     <!-- Div to correctly display parallax effect with background sliding over image -->
    <div class = "page-background u-z-2 u-relative">

        <div class="u-container u-mt-fluid-xl u-pt-2">
            <div class="w-full u-mt-4 u-h-[50vh] heading-box u-text-center u-flex u-items-center u-justify-center">
                <p class = "glitchable heading-box-text u-tracking-wide">PROJECTS</p>
            </div>
            <div class="w-full u-mt-12 u-h-[50vh] heading-box u-text-center u-flex u-items-center u-justify-center">
                <p class = "glitchable heading-box-text tracking-work">MY WORK</p>
            </div>
            <div class="w-full u-mt-12 u-h-[50vh] heading-box u-text-center u-flex u-items-center u-justify-center">
                <p class = "glitchable heading-box-text tracking-about">ABOUT ME</p>
            </div>
            <div class="w-full u-mt-12 u-h-[50vh] heading-box u-text-center u-flex u-items-center u-justify-center">
                <p class = "glitchable heading-box-text tracking-contact">CONTACT</p>
            </div>

            <div class="u-mt-12 u-grid u-grid-cols-2 u-gap-gutter">
                <div>
                    <Image
                        src="https://locomotive.ca/uploads/careers/pltropics-2000w.jpg"
                        alt="Placeholder alt"
                        caption="Loading lazy native"
                        loading="lazy"
                        width={500}
                        height={500}
                        data-scroll="" 
                        data-scroll-offset="15%" 
                        data-scroll-call="lazyLoad, Scroll" 
                        data-depixelate=""
                    />
                </div>
                <div>
                    <Image
                        src="https://locomotive.ca/uploads/careers/fullscreen-image-2000w.jpg"
                        alt="Placeholder alt"
                        caption="Loading lazy native + locomotive-scroll inview anim"
                        loading="lazy"
                        width={500}
                        height={500}
                        data-scroll="" 
                        data-scroll-offset="15%" 
                        data-scroll-call="lazyLoad, Scroll" 
                        data-depixelate=""
                    />
                </div>
            </div>
            <div class="w-full u-mt-fluid-xl u-h-[50vh] u-bg-[#9ab28a]"></div>
        </div>
    </div>

    <script type="module">
        //Imports for gsap to setup animation for the cover image
        import gsap from '../../node_modules/gsap';
        import { ScrollTrigger } from '../../node_modules/gsap/ScrollTrigger';
        gsap.registerPlugin(ScrollTrigger);
        ScrollTrigger.defaults({
            fastScrollEnd: true,
        });

        //Run on content loaded
        document.addEventListener("DOMContentLoaded", () => {
            //Load in elements from HTML
            const canvas = document.getElementById("parallax-canvas");
            const hero = document.getElementById("parallax-hero");
            const name = document.getElementById("parallax-name");
            const namecopy = document.getElementById("parallax-name-copy");
            const title = document.getElementById("parallax-title");
            const logo = document.getElementById("parallax-logo");
            const glitchables = document.querySelectorAll('.glitchable');

            //Set up canvas
            const context = canvas.getContext("2d");
            canvas.width = 1920;
            canvas.height = 1080;

            //Ensure that all elements exist, otherwise don't continue
            if (!hero || !name || !title || !logo || !canvas || !context) { return; }

            //Set up sprite sheets for hero canvas content
            const spriteSheet1 = new Image();
            spriteSheet1.src = "/assets/images/sprite_sheet_alt_1.png";
            const spriteSheet2 = new Image();
            spriteSheet2.src = "/assets/images/sprite_sheet_alt_2.png";
            //Set up important info for sprite sheets/canvas
            const columns = 5; // 10 frames per row
            const frameCount = 60;

             //When window loads, preload and predraw frames
             window.onload = () => {
                preloadFrames();
                startAnimation(); // Now run GSAP animation
            };

            //Separate context to load images
            const bufferCtx = canvas.getContext("2d");
            //Preload all frames to avoid lag when loading/moving back to the tab after a long time
            function preloadFrames() {
                for (let i = 0; i < frameCount; i++) {
                    let spriteSheet = i > 30 ? spriteSheet2 : spriteSheet1;
                    let localFrameIndex = i > 30 ? i - 30 : i;
                    let col = localFrameIndex % columns;
                    let row = Math.floor(localFrameIndex / columns);

                    let sx = col * canvas.width;
                    let sy = row * canvas.height;

                    bufferCtx.drawImage(spriteSheet, sx, sy, canvas.width, canvas.height, 0, 0, canvas.width, canvas.height);
                }
                //Redraw first frame to start on the correct one
                bufferCtx.drawImage(spriteSheet1, 0, 0, canvas.width, canvas.height, 0, 0, canvas.width, canvas.height);
            }

            //Variable for running GSAP animation
            const glassrender = { frame: 0 };

            //Gsap function to animate on scroll
            function startAnimation() {
                gsap.to(glassrender, {
                    frame: frameCount - 1,
                    snap: "frame",
                    ease: "none",
                    scrollTrigger: {
                        scrub: 0,
                        start: "top top",
                        end: () => `${hero.offsetHeight*0.7}px`,
                    },
                    //Run custom render function on scroll
                    onUpdate: render,
                });
            }

            //Properly render current frame based on scroll progress
            function render() {
                //Clear canvas, set up frame index
                context.clearRect(0, 0, canvas.width, canvas.height);
                let frameIndex = glassrender.frame;
                console.log(frameIndex);

                //Determine which sprite sheet/index to use
                let spriteSheet = frameIndex >= 30 ? spriteSheet2 : spriteSheet1;
                frameIndex -= frameIndex >= 30 ? 30: 0;
                
                //Get column, row, and pixel locations from sprite sheet to draw correct image
                let col = frameIndex % columns;
                let row = Math.floor(frameIndex / columns);
                let sx = col * canvas.width;
                let sy = row * canvas.height;

                //Draw the current frame
                context.drawImage(spriteSheet, sx, sy, canvas.width, canvas.height, 0, 0, canvas.width, canvas.height);
            }

            //Shuffle name title text on hover
            function shuffleText(text) {
                // Split the text into words and handle punctuation
                const words = text.split(' ').map(word => {
                    // Separate letters and punctuation within each word
                    const letters = word.replace(/[^a-zA-Z]/g, '');  // Only alphabetic characters
                    const punctuation = word.replace(/[a-zA-Z]/g, '');  // Only punctuation to leave periods at the end

                    // Randomly shuffle the letters
                    let shuffledLetters = letters.split('');
                    for (let i = shuffledLetters.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [shuffledLetters[i], shuffledLetters[j]] = [shuffledLetters[j], shuffledLetters[i]];
                    }

                    // Return shuffled letters followed by punctuation
                    return shuffledLetters.join('') + punctuation;
                });

                // Join the words back with spaces
                return words.join(' ');
            }

            glitchables.forEach((el) => {
                let originalText = el.textContent;
                let glitchInterval;

                function glitchText() {
                    glitchInterval = setInterval(() => {
                        el.textContent = shuffleText(originalText);
                    }, 50);

                    setTimeout(() => {
                        clearInterval(glitchInterval);
                        el.textContent = originalText;
                    }, 250);
                }

                el.addEventListener("mouseenter", glitchText);

                el.addEventListener("mouseleave", () => {
                    clearInterval(glitchInterval);
                    el.textContent = originalText;
                });
            });
            
            //Move hero page text on scroll with a parallax effect
            document.addEventListener("scroll", () => {
                const scrollY = window.scrollY;
                
                canvas.style.transform = `translateY(${scrollY * 0.5}px)`;
                name.style.transform = `translateY(${scrollY * -0.27}px)`;
                namecopy.style.transform = `translateY(${scrollY * -0.27}px)`;
                title.style.transform = `translateY(${scrollY * -0.15}px)`;
                logo.style.transform = `translateY(${scrollY * -0.2}px)`;
            });
        });
      </script>

    <style>

        /*Remove horizontal scrolling in some browsers caused by canvas image
        e4c787*/
        html body {
            overflow-x: hidden;
            background-color: #e4c787;
        }
        
        .page-background {
            background-color: #e4c787;
        }

        /* Custom font using free trial license from Pangram Pangram Foundry: https://pangrampangram.com/pages/faq*/
        @font-face {
            font-family: 'Supply';
            src: url('/fonts/Supply/PPSupplySans-Regular.woff2') format('woff2');
            font-weight: 400;
            font-style: normal;
        }
        @font-face {
            font-family: 'Neue-Mono';
            src: url('/fonts/NeueMono/PPNeueMontrealMono-Book.otf') format('opentype');
            font-weight: 200;
            font-style: normal;
        }
        @font-face {
            font-family: 'Nikkei';
            src: url('/fonts/Nikkei/PPNikkeiLine-Light.otf') format('opentype');
            font-weight: 200;
            font-style: normal;
        }

        .hero {
            position: relative;
            height: 100vh;
            background-image: url('assets/images/animation2/0001.webp'); /* Fallback image if canvas doesn't load */
            background-size: cover;
            background-position: center;
            background-attachment: scroll; /* Allow for parallax effect */
        }

        .parallax-canvas {
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            position: relative;
        }

        .hero-content {
            position: absolute;
            bottom: 20px;
            left: 20px;
            font-size: 2rem;
            display: grid; /* Display content in proper relative location */
        }

        .icon-text-wrapper {
            display: flex;
            align-items: center; /* Vertically align icon and text */
            gap: 0.5em; /* Space between icon and text */
            padding-left: 0.3em;
            padding-bottom: 0.3em;
            font-family: 'Supply';
            user-select: none;
        }

        .icon {
            width: 2.5em;
            height: 2.65em;
            z-index: 2;
            position: relative;
            user-select: none;
        }

        .title-font {
            font-size: 17.5vw;
            line-height: 1.2;
            font-family: 'Supply';
        }

        .parallax-name-copy {
            position: absolute;
            z-index: 5;
            color: transparent;
        }

        /*Alternate Color Scheme:
            color: #fde68a;    
            background-color: #2c1300;
        */
        .parallax-name-copy::selection {
            color: #9ab28a;
            background-color: #593636;
        }

        .heading-box {
            font-size: 16vw;
            line-height: 1.2;
            font-family: 'Nikkei';
            background-color: #192727;
            color: #e4c787;
        }

        .heading-box:hover {
            outline: 25px solid #192727;
            background-color: #9ab28a;
            color: #593636;
        }

        .heading-box-text::selection {
            color: #9ab28a;
            background-color: #593636;
        }

        .tracking-work {
            letter-spacing: 0.117em;
        }

        .tracking-about {
            letter-spacing: 0.035em;
        }

        .tracking-contact {
            letter-spacing: 0.115em;
        }

        /*Properties for larger screens*/
        @media (min-width: 720px) {
            .title-font {
                font-size: 4em;
            }
        }
        /*Properties for smaller screens */
        @media (max-width: 720px) {
            .heading-box {
                height: 20vh;
            }
        }
    </style>
</Layout>





