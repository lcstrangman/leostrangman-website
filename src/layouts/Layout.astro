---
import '@styles/main.scss';
import '@styles/custom.css';
import { SEO } from 'astro-seo';
import { defaultSeo } from '@data/seo';
import { getSeo } from '@scripts/utils/seo';

interface Props {
    title: string;
    seo?: Seo;
    backgroundColor?: string;
    altColor?: string;
}

const { title, seo = {}, backgroundColor = "#e4c787", altColor = "#192727" } = Astro.props;

const seoData = getSeo(seo, defaultSeo, title);

const FONTS: string[] = [
    // 'WebfontRegular.woff2',
    // 'WebfontBold.woff2',
];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        <link rel="icon" href="/favicon.png" type="image/png">
        <link rel="icon" href="/favicon.ico" type="image/x-icon">
        <meta name="generator" content={Astro.generator} />

        <SEO {...seoData} />

        <!-- Fonts -->
        {
            FONTS.map((font) => (
                <link
                    rel="preload"
                    href={`/fonts/${font}`}
                    as="font"
                    type="font/woff2"
                    crossorigin
                />
            ))
        }
    </head>
    <body style={`--background-color: ${backgroundColor}; --alt-color: ${altColor}`}>
        <script is:inline>
            if (window.performance && window.performance.navigation.type === 1) {
                // This is a reload, don't scroll
            } else if (window.history.length > 1 && window.location.hash === "") {
                // Not a reload, not a hash link, scroll to top
                window.scrollTo(0, 0);
            }
        </script>
        <!--
        <div class="u-container">
            <nav class="u-flex u-gap-gutter u-py-fluid-md">
                <a href="/">Index</a>
                <a href="/about">About</a>
                <a href="/post">The post</a>
            </nav>
        </div>
        -->
        

        <main id="swup" class="transition-fade">
            <div id="content">
                <slot />
            </div>
        </main>

        <footer class="u-container u-flex u-justify-between u-py-fluid-xs font-nikkei background-color" style="color: var(--alt-color);">
            <div>
                &copy;{new Date().getFullYear()}
            </div>

            <nav class="u-flex u-gap-gutter font-nikkei">
                <a class = "glitchable hover-text" href="/">Index</a>
                <a class = "glitchable hover-text" href="/projects">Projects</a>
                <a class = "glitchable hover-text" href="/work">My Work</a>
                <a class = "glitchable hover-text" href="/about">About Me</a>
                <a class = "glitchable hover-text" href="/contact">Contact</a>
            </nav>
        </footer>
        <script src="../scripts/app.ts"></script>
        <script>
            import { setViewportSize } from '@scripts/utils/setViewportSize';
            import { $screenDebounce } from '@scripts/stores/screen';

            // Set viewport size
            $screenDebounce.subscribe(() => {
                setViewportSize();
            });
        </script>
        <style>
            .font-nikkei {
                font-family: "Nikkei";
            }
        </style>
    </body>
</html>